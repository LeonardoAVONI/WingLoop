%implements s1_b0_yslnd_Outputs "C"

%function Outputs(block, system) Output
%assign cfgTxt = ""
%openfile cfgTxt
%assign localVarDecl = ""
%openfile localVarDecl

__m128d tmp_0;
real_T rtb_Gain[6];
real_T tmp[2];
int32_T i;
%closefile localVarDecl
%<SLibCG_TrackEO(5)>\
%<SLibCG_TrackEO(4)>\
%<SLibCG_TrackEO(3)>\
%<SLibCG_TrackEO(2)>\
%<SLibCG_TrackEO(1)>\
%<SLibCG_TrackEO(0)>\
%<SLibCG_TrackEI(0)>\
for (i = 0; i <= 4; i += 2) {
    _mm_storeu_pd(&rtb_Gain[i], _mm_mul_pd(_mm_set1_pd(simulink_test_controller_P.Gain_Gain), _mm_loadu_pd(&simulink_test_controller_U.statein[i])));
}
_mm_storeu_pd(&tmp[0], _mm_add_pd(_mm_set_pd(simulink_test_controller_P.workspace_matrix[0], rtb_Gain[0]), _mm_set_pd(rtb_Gain[1], simulink_test_controller_P.workspace_scalar)));
simulink_test_controller_Y.F1 = tmp[0];
simulink_test_controller_Y.F2 = tmp[1];
tmp_0 = _mm_add_pd(_mm_set_pd(simulink_test_controller_P.Constant8_Value, simulink_test_controller_P.Constant6_Value), _mm_loadu_pd(&rtb_Gain[2]));
_mm_storeu_pd(&tmp[0], tmp_0);
simulink_test_controller_Y.F3 = tmp[0];
simulink_test_controller_Y.F4 = tmp[1];
_mm_storeu_pd(&tmp[0], _mm_add_pd(_mm_set_pd(rtb_Gain[5], simulink_test_controller_P.Constant1_Value), _mm_set_pd(simulink_test_controller_P.Constant2_Value, rtb_Gain[4])));
simulink_test_controller_Y.E1 = tmp[0];
simulink_test_controller_Y.E2 = tmp[1];
%<SLibInsertSolverResetCode()>\
%closefile cfgTxt
%<cfgTxt>
%<LibSetSystemField(system, "CachedOutputLocalVars", localVarDecl)>
%endfunction
%function OutputsFcnProtoType(block, system) Output
%assign fcnProtoType = ""
%openfile fcnProtoType
static void Outputs(\
%assign comma = ""
%closefile fcnProtoType
%<SLibCG_SetFcnProtoType(0, 1, fcnProtoType)>
%endfunction
